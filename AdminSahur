-- Visual helpers (RED THEME)
local function r8(o) local c = Instance.new("UICorner", o); c.CornerRadius = UDim.new(0,8); return c end
local function r12(o) local c = Instance.new("UICorner", o); c.CornerRadius = UDim.new(0,12); return c end

local function stroke(o, a)
    local s = Instance.new("UIStroke", o)
    s.Transparency = a or 0.65
    s.Color = Color3.fromRGB(255, 60, 60)
    s.Thickness = 1.4
    s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    return s
end

local function redGlass(o)
    o.BackgroundColor3 = Color3.fromRGB(35, 0, 0)
    o.BackgroundTransparency = 0.12
    stroke(o, 0.6)
    local g = Instance.new("UIGradient", o)
    g.Rotation = 90
    g.Color = ColorSequence.new{
        ColorSequenceKeypoint.new(0, Color3.fromRGB(90, 10, 10)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(25, 0, 0))
    }
end

local function mkLabel(parent, text, size, y, bold, center)
    local l = Instance.new("TextLabel", parent)
    l.Size = UDim2.new(1, -20, 0, size + 10)
    l.Position = UDim2.fromOffset(10, y or 0)
    l.BackgroundTransparency = 1
    l.Text = text
    l.Font = bold and Enum.Font.GothamSemibold or Enum.Font.Gotham
    l.TextSize = size
    l.TextColor3 = Color3.fromRGB(255, 220, 220)
    l.TextXAlignment = center and Enum.TextXAlignment.Center or Enum.TextXAlignment.Left
    return l
end

local function mkBtn(parent, pos, size, text, bg, z)
    local b = Instance.new("TextButton", parent)
    b.Position = pos
    b.Size = size
    b.Text = text
    b.ZIndex = z or 11
    b.Font = Enum.Font.GothamSemibold
    b.TextSize = 14
    b.TextColor3 = Color3.fromRGB(255, 230, 230)
    b.BackgroundColor3 = bg or Color3.fromRGB(140, 20, 20)
    r8(b)
    stroke(b, 0.5)
    return b
end

-- Drag system (mobile friendly)
local function pointerInGuiSpace(target)
    local p = UIS:GetMouseLocation()
    local inset = GuiService:GetGuiInset()
    local sg = target:FindFirstAncestorWhichIsA("ScreenGui")
    if sg and not sg.IgnoreGuiInset then
        return Vector2.new(p.X - inset.X, p.Y - inset.Y)
    end
    return p
end

local function clampToParent(target, absX, absY)
    local parent = target.Parent
    local ox, oy = parent.AbsolutePosition.X, parent.AbsolutePosition.Y
    local pw, ph = parent.AbsoluteSize.X, parent.AbsoluteSize.Y
    local tw, th = target.AbsoluteSize.X, target.AbsoluteSize.Y
    local cx = math.clamp(absX, ox, ox + pw - tw)
    local cy = math.clamp(absY, oy, oy + ph - th)
    return UDim2.fromOffset(cx - ox, cy - oy)
end

local function addDrag(handle, target, opts)
    opts = opts or {}
    local DEADZONE = opts.deadzone or 6
    local dragging, candidate = false, false
    local startTime = 0
    local offsetAbs = Vector2.zero
    local stepConn

    local function stopDrag()
        dragging = false
        candidate = false
        if stepConn then stepConn:Disconnect() end
        if opts.onRelease then opts.onRelease() end
    end

    handle.InputBegan:Connect(function(input)
        if input.UserInputType \~= Enum.UserInputType.MouseButton1 and input.UserInputType \~= Enum.UserInputType.Touch then return end
        candidate = true
        startTime = os.clock()
        local ptr = pointerInGuiSpace(target)
        offsetAbs = target.AbsolutePosition - ptr

        stepConn = RunS.RenderStepped:Connect(function()
            if not candidate then return end
            local ptrNow = pointerInGuiSpace(target)
            if not dragging then
                local dx = math.abs(ptrNow.X - (target.AbsolutePosition.X - offsetAbs.X))
                local dy = math.abs(ptrNow.Y - (target.AbsolutePosition.Y - offsetAbs.Y))
                if (os.clock() - startTime)*1000 >= (opts.hold_ms or 0) or dx > DEADZONE or dy > DEADZONE then
                    dragging = true
                else
                    return
                end
            end
            local absX = ptrNow.X + offsetAbs.X
            local absY = ptrNow.Y + offsetAbs.Y
            target.Position = clampToParent(target, absX, absY)
        end)

        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End or input.UserInputState == Enum.UserInputState.Cancel then
                stopDrag()
            end
        end)
    end)

    UIS.TouchEnded:Connect(stopDrag)
end

local function ensureVisible(win, key)
    task.defer(function()
        if not win or not win.Parent then return end
        local p = win.AbsolutePosition
        win.Position = clampToParent(win, p.X, p.Y)
        if key then savePos(key, win) end
    end)
end

local function normalizeMutationEmpty(s)
    s = tostring(s or ""):match("^%s*(.-)%s*$")
    if s == "" or s:lower() == "normal" then return "" end
    return s
end

-- Traits multi-select dropdown (same as original)
local function AttachTraitsDropdown(win, opts)
    local PADDING = 10
    local BTN_H   = 34
    local y0      = opts.y or 138
    local z       = opts.z or 22
    local baseH   = opts.baseHeight or win.Size.Y.Offset
    local panelH  = opts.panelH or 180

    local btn = Instance.new("TextButton")
    btn.Name = "TraitsBtn"
    btn.Parent = win
    btn.Position = UDim2.fromOffset(PADDING, y0)
    btn.Size = UDim2.new(1, -2*PADDING, 0, BTN_H)
    btn.Text = "Traits (0)"
    btn.Font = Enum.Font.GothamSemibold
    btn.TextSize = 15
    btn.TextColor3 = Color3.fromRGB(255, 210, 210)
    btn.BackgroundColor3 = Color3.fromRGB(50, 0, 0)
    btn.ZIndex = z
    r8(btn)
    stroke(btn, 0.5)

    local panel = Instance.new("Frame")
    panel.Name = "TraitsPanel"
    panel.Parent = win
    panel.Position = UDim2.fromOffset(PADDING, y0 + BTN_H + 4)
    panel.Size = UDim2.new(1, -2*PADDING, 0, 0)
    panel.BackgroundColor3 = Color3.fromRGB(25, 0, 0)
    panel.BackgroundTransparency = 1
    panel.Visible = false
    panel.ClipsDescendants = true
    panel.ZIndex = z
    r12(panel)

    local pad = Instance.new("UIPadding", panel)
    pad.PaddingTop = pad.PaddingBottom = pad.PaddingLeft = pad.PaddingRight = UDim.new(0,6)

    local scroll = Instance.new("ScrollingFrame", panel)
    scroll.Size = UDim2.new(1,0,1,0)
    scroll.BackgroundTransparency = 1
    scroll.ScrollBarThickness = 4
    scroll.ZIndex = z

    local list = Instance.new("UIListLayout", scroll)
    list.SortOrder = Enum.SortOrder.LayoutOrder
    list.Padding = UDim.new(0,5)

    local function refreshCanvas()
        task.wait()
        scroll.CanvasSize = UDim2.new(0,0,0,list.AbsoluteContentSize.Y + 10)
    end
    list:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(refreshCanvas)

    local TRAIT_LIST = {
        "All", "Taco", "Nyan", "Galactic", "Fireworks", "Zombie", "Claws", "Glitched", "Bubblegum",
        "Fire", "Wet", "Snowy", "Comet-struck", "Explosive", "Disco", "10B", "Shark Fin", "Matteo Hat",
        "Brazil", "Sleepy", "Lightning", "UFO", "Spider", "Strawberry", "Paint", "Skeleton",
        "Sombrero", "Tie", "Witch Hat", "Indonesia", "Meowl"
    }

    local selected = {}
    local function countSel()
        local n = 0
        for _,v in selected do if v then n += 1 end end
        return n
    end

    local function refreshBtn()
        btn.Text = "Traits (" .. countSel() .. ")"
    end

    local items = {}
    local function setAll(state)
        for _, it in items do
            local nm = it.Name:sub(7)
            selected[nm] = state
            it.BackgroundTransparency = state and 0.1 or 0.3
            local mark = it:FindFirstChild("Mark")
            if mark then mark.Text = state and "✔" or "" end
        end
        refreshBtn()
    end

    local function makeItem(name)
        local it = Instance.new("Frame")
        it.Name = "Trait_" .. name
        it.Parent = scroll
        it.Size = UDim2.new(1, -10, 0, 32)
        it.BackgroundColor3 = Color3.fromRGB(45, 0, 0)
        it.BackgroundTransparency = 0.3
        it.ZIndex = z
        r8(it)

        local lbl = Instance.new("TextLabel", it)
        lbl.BackgroundTransparency = 1
        lbl.Size = UDim2.new(1, -50, 1, 0)
        lbl.Position = UDim2.fromOffset(12, 0)
        lbl.Font = Enum.Font.Gotham
        lbl.TextSize = 15
        lbl.TextXAlignment = Enum.TextXAlignment.Left
        lbl.Text = name
        lbl.TextColor3 = Color3.fromRGB(255, 220, 220)
        lbl.ZIndex = z

        local mark = Instance.new("TextLabel", it)
        mark.Name = "Mark"
        mark.BackgroundTransparency = 1
        mark.Size = UDim2.new(0, 30, 1, 0)
        mark.Position = UDim2.new(1, -35, 0, 0)
        mark.Font = Enum.Font.GothamBold
        mark.TextSize = 18
        mark.TextColor3 = Color3.fromRGB(180, 255, 180)
        mark.ZIndex = z

        local hit = Instance.new("TextButton", it)
        hit.BackgroundTransparency = 1
        hit.Size = UDim2.new(1,0,1,0)
        hit.Text = ""
        hit.ZIndex = z
        hit.Activated:Connect(function()
            if name == "All" then
                local turn = not selected["All"]
                selected["All"] = turn
                setAll(turn)
                return
            end

            selected[name] = not selected[name]
            it.BackgroundTransparency = selected[name] and 0.1 or 0.3
            mark.Text = selected[name] and "✔" or ""

            local allOn = true
            for _, t in TRAIT_LIST do
                if t \~= "All" and not selected[t] then allOn = false break end
            end
            selected["All"] = allOn
            refreshBtn()
        end)

        table.insert(items, it)
    end

    for _, t in TRAIT_LIST do makeItem(t) end
    refreshCanvas()

    local isOpen = false

    local function openPanel()
        isOpen = true
        panel.Visible = true
        TweenService:Create(win, TweenInfo.new(0.25, Enum.EasingStyle.Quad), {Size = UDim2.new(0, win.Size.X.Offset, 0, baseH + panelH + 8)}):Play()
        local grow = TweenService:Create(panel, TweenInfo.new(0.25, Enum.EasingStyle.Quad), {Size = UDim2.new(1,0,0,panelH)})
        grow:Play()
        grow.Completed:Connect(function()
            TweenService:Create(panel, TweenInfo.new(0.15), {BackgroundTransparency = 0.1}):Play()
            for i, it in ipairs(items) do
                task.delay((i-1)*0.015, function()
                    local nm = it:FindFirstChildWhichIsA("TextLabel").Text
                    TweenService:Create(it, TweenInfo.new(0.18), {BackgroundTransparency = selected[nm] and 0.1 or 0.3}):Play()
                    for _, ch in it:GetChildren() do
                        if ch:IsA("TextLabel") then
                            TweenService:Create(ch, TweenInfo.new(0.18), {TextTransparency = 0}):Play()
                        end
                    end
                end)
            end
        end)
    end

    local function closePanel()
        isOpen = false
        TweenService:Create(panel, TweenInfo.new(0.18), {BackgroundTransparency = 1}):Play()
        TweenService:Create(panel, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {Size = UDim2.new(1,0,0,0)}):Play()
        TweenService:Create(win, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {Size = UDim2.new(0, win.Size.X.Offset, 0, baseH)}):Play()
        task.delay(0.26, function() panel.Visible = false end)
    end

    btn.Activated:Connect(function()
        if isOpen then closePanel() else openPanel() end
    end)

    win:GetPropertyChangedSignal("Size"):Connect(function()
        btn.Size = UDim2.new(1, -2*PADDING, 0, BTN_H)
        panel.Size = UDim2.new(1, -2*PADDING, 0, panel.Size.Y.Offset)
        panel.Position = UDim2.fromOffset(PADDING, y0 + BTN_H + 4)
    end)

    local function traitsArray()
        local arr = {}
        for k,v in selected do if v then table.insert(arr, k) end end
        table.sort(arr)
        return arr
    end

    local function traitsString()
        local arr = traitsArray()
        if table.find(arr, "All") then return "All" end
        return #arr > 0 and table.concat(arr, ", ") or ""
    end

    return {
        GetTraits  = traitsArray,
        GetString  = traitsString,
        IsOpen     = function() return isOpen end,
        Open       = function() if not isOpen then openPanel() end end,
        Close      = function() if isOpen then closePanel() end end,
    }
end

